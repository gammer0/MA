# ============================================================
# PostgreSQL
# ============================================================
PG_PASSWORD=changeme_in_production

# ============================================================
# API Keys 服务间调用
# ========================================================
SERVICE_API_KEY=service-secret-key-dev

# ============================================================
# LLM API (飞书 Demo App 用)
# ============================================================
LLM_API_KEY=sk-your-api-key-here              # DeepSeek / OpenAI API Key
LLM_API_BASE=https://api.deepseek.com          # API 端点（OpenAI 改为 https://api.openai.com/v1）
LLM_MODEL=deepseek-v4-flash                    # 模型名（如 gpt-4o-mini / deepseek-v4-flash）

# ============================================================
# 飞书应用凭证 (飞书 Demo App 用)
# ============================================================
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx            # 飞书应用 App ID
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx     # 飞书应用 App Secret
